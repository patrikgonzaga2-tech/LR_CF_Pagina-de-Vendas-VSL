<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Comunidade Corpo Feliz — Treinos Hormonais · Laüra Rosa</title>
  <meta name="robots" content="noindex,nofollow">
  <script>
    (function () {
      var pages = [
        'corpo-feliz-var5.html',
        'corpo-feliz-var6.html',
        'corpo-feliz-var9.html',
        'corpo-feliz-var14.html'
      ];
      var variants = ['v5','v6','v9','v14'];
      var idx  = Math.floor(Math.random() * pages.length);
      var sp   = new URLSearchParams(window.location.search);
      sp.set('variante', variants[idx]);
      var hash = window.location.hash;
      window.location.replace(pages[idx] + '?' + sp.toString() + hash);
    })();
  </script>
  <noscript>
    <meta http-equiv="refresh" content="0;url=corpo-feliz-var9.html">
  </noscript>
</head>
<body></body>
</html>
